<Window x:Class="ADOPipelinesToaster.Views.PipelinePopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pipeline Status"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <!-- Status color converter via style triggers -->
        <Style x:Key="StatusBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="Background" Value="#888"/>
        </Style>
    </Window.Resources>

    <Border Background="#1E1E1E" Padding="12">
        <StackPanel>
            <!-- Header -->
            <TextBlock Text="ADO Pipeline Status"
                       Foreground="#CCCCCC" FontSize="13" FontWeight="SemiBold"
                       Margin="0,0,0,10"/>

            <!-- Loading indicator -->
            <TextBlock Text="Loading..."
                       Foreground="#888" FontSize="12"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                       Margin="0,0,0,6"/>

            <!-- Error / empty message -->
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#E57373" FontSize="11" TextWrapping="Wrap"
                       Margin="0,0,0,6"
                       Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibility}}"/>

            <!-- Pipeline runs list -->
            <ItemsControl ItemsSource="{Binding Runs}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#2D2D2D" CornerRadius="5" Padding="10" Margin="0,0,0,8">
                            <StackPanel>
                                <!-- Run name + overall status -->
                                <DockPanel>
                                    <TextBlock FontSize="12" FontWeight="Medium"
                                               DockPanel.Dock="Left" TextTrimming="CharacterEllipsis">
                                        <Hyperlink NavigateUri="{Binding WebUrl}" RequestNavigate="Hyperlink_RequestNavigate"
                                                   Foreground="#6CB6FF" TextDecorations="None">
                                            <Run Text="{Binding Name}"/>
                                        </Hyperlink>
                                    </TextBlock>
                                    <Border CornerRadius="3" Padding="5,1" HorizontalAlignment="Right"
                                            Background="{Binding Result, Converter={StaticResource ResultToColor}}">
                                        <TextBlock Text="{Binding Result}" Foreground="White" FontSize="10"/>
                                    </Border>
                                </DockPanel>

                                <!-- Stages -->
                                <ItemsControl ItemsSource="{Binding Stages}" Margin="0,6,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="3" Padding="5,2" Margin="0,0,4,4"
                                                    Background="{Binding Result, Converter={StaticResource ResultToColor}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <!-- Spinning icon shown only when stage is running -->
                                                    <TextBlock Foreground="White" FontSize="10" Margin="0,0,3,0"
                                                               Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock.RenderTransformOrigin>0.5,0.5</TextBlock.RenderTransformOrigin>
                                                        <TextBlock.RenderTransform>
                                                            <RotateTransform/>
                                                        </TextBlock.RenderTransform>
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="⟳"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                        <DataTrigger.EnterActions>
                                                                            <BeginStoryboard>
                                                                                <Storyboard RepeatBehavior="Forever">
                                                                                    <DoubleAnimation
                                                                                        Storyboard.TargetProperty="(TextBlock.RenderTransform).(RotateTransform.Angle)"
                                                                                        From="0" To="360" Duration="0:0:1"/>
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </DataTrigger.EnterActions>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="10"/>
                                                    <TextBlock Text=": " Foreground="White" FontSize="10"/>
                                                    <TextBlock Text="{Binding Result}" Foreground="White" FontSize="10"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</Window>
