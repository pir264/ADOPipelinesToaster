<Window x:Class="ADOPipelinesToaster.Views.PipelinePopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pipeline Status"
        Width="420" MinHeight="100" MaxHeight="600"
        SizeToContent="Height"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <!-- Status color converter via style triggers -->
        <Style x:Key="StatusBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="Background" Value="#888"/>
        </Style>
    </Window.Resources>

    <Border Background="#1E1E1E" Padding="12">
        <StackPanel>
            <!-- Header -->
            <TextBlock Text="ADO Pipeline Status"
                       Foreground="#CCCCCC" FontSize="13" FontWeight="SemiBold"
                       Margin="0,0,0,10"/>

            <!-- Loading indicator -->
            <TextBlock Text="Loading..."
                       Foreground="#888" FontSize="12"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                       Margin="0,0,0,6"/>

            <!-- Error / empty message -->
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#E57373" FontSize="11" TextWrapping="Wrap"
                       Margin="0,0,0,6"
                       Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibility}}"/>

            <!-- Pipeline runs list -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Runs}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#2D2D2D" CornerRadius="5" Padding="10" Margin="0,0,0,8">
                            <StackPanel>
                                <!-- Run name + overall status -->
                                <DockPanel>
                                    <TextBlock FontSize="12" FontWeight="Medium"
                                               DockPanel.Dock="Left" TextTrimming="CharacterEllipsis">
                                        <Hyperlink NavigateUri="{Binding WebUrl}" RequestNavigate="Hyperlink_RequestNavigate"
                                                   Foreground="#6CB6FF" TextDecorations="None">
                                            <Run Text="{Binding Name}"/>
                                        </Hyperlink>
                                    </TextBlock>
                                    <TextBlock Text="✓" Foreground="#4CAF50" FontSize="13" FontWeight="Bold"
                                               DockPanel.Dock="Right" VerticalAlignment="Center" Margin="6,0,4,0"
                                               Visibility="{Binding AllStagesCompleted, Converter={StaticResource BoolToVisibility}}"
                                               ToolTip="All stages completed"/>
                                    <Border DockPanel.Dock="Right" CornerRadius="3" Padding="5,1" Margin="4,0,0,0"
                                            Background="#E65100" VerticalAlignment="Center"
                                            Visibility="{Binding HasNewerRunByOther, Converter={StaticResource BoolToVisibility}}"
                                            ToolTip="{Binding NewerRunBy, StringFormat='⚠ Newer run started by {0}'}">
                                        <TextBlock Text="⚠ newer run" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                    </Border>
                                    <Button DockPanel.Dock="Right" Content="✕"
                                            ToolTip="Exclude this pipeline"
                                            Click="OnExcludeClick"
                                            Background="Transparent" Foreground="#666"
                                            BorderThickness="0" Padding="4,0" FontSize="10"
                                            Cursor="Hand" VerticalAlignment="Center"/>
                                    <Border Width="12" Height="12" CornerRadius="6" HorizontalAlignment="Right"
                                            Background="{Binding Result, Converter={StaticResource ResultToColor}}"
                                            ToolTip="{Binding Result}"
                                            Visibility="{Binding Result, Converter={StaticResource StringToVisibility}}"/>
                                </DockPanel>

                                <!-- Stages -->
                                <ItemsControl ItemsSource="{Binding Stages}" Margin="0,6,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="3" Padding="5,2" Margin="0,0,4,4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{Binding Result, Converter={StaticResource ResultToColor}}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                <Setter Property="Background" Value="#1565C0"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <!-- Spinning icon shown only when stage is running -->
                                                    <TextBlock Foreground="White" FontSize="10" Margin="0,0,3,0"
                                                               Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock.RenderTransformOrigin>0.5,0.5</TextBlock.RenderTransformOrigin>
                                                        <TextBlock.RenderTransform>
                                                            <RotateTransform/>
                                                        </TextBlock.RenderTransform>
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="⟳"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                        <DataTrigger.EnterActions>
                                                                            <BeginStoryboard>
                                                                                <Storyboard RepeatBehavior="Forever">
                                                                                    <DoubleAnimation
                                                                                        Storyboard.TargetProperty="(TextBlock.RenderTransform).(RotateTransform.Angle)"
                                                                                        From="0" To="360" Duration="0:0:1"/>
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </DataTrigger.EnterActions>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock FontSize="10">
                                                        <Hyperlink NavigateUri="{Binding WebUrl}" RequestNavigate="Hyperlink_RequestNavigate"
                                                                   Foreground="White" TextDecorations="None">
                                                            <Run Text="{Binding Name}"/>
                                                        </Hyperlink>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Result, Converter={StaticResource ResultToLabel}}"
                                                               Foreground="White" FontSize="10"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            </ScrollViewer>
        </StackPanel>
    </Border>
</Window>
