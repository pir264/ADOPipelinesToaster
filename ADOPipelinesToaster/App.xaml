<Application x:Class="ADOPipelinesToaster.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ADOPipelinesToaster.Converters"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <conv:ResultToColorConverter x:Key="ResultToColor"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:StringToVisibilityConverter x:Key="StringToVisibility"/>
    </Application.Resources>
</Application>
